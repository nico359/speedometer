<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.nico359.speedometer</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Speedometer</name>
  <summary>GPS speedometer (mostly) for Linux phones</summary>
  <description>
    <p>Speedometer is a GPS-based speedometer designed for mobile Linux devices. It displays your current speed on an analogue dial with a colour-coded arc, a large digital readout, altitude and also coordinates - all sourced from the XDG Location Portal.</p>
    <p>The GPS accuracy indicator shows whether the location fix is good enough to determine speed, making it clear when only a network-based position is available (yellow dot).</p>
    <p>Disclaimer: For informational purposes only. Speed readings are GPS-based and approximate - not legally certified for any purpose. Do not use while driving.</p>
  </description>

  <icon type="stock">io.github.nico359.speedometer</icon>

  <developer id="io.github.nico359">
    <name>nico359</name>
  </developer>

  <url type="homepage">https://github.com/nico359/speedometer</url>
  <url type="vcs-browser">https://github.com/nico359/speedometer</url>
  <url type="bugtracker">https://github.com/nico359/speedometer/issues</url>

  <recommends>
    <display_length compare="ge">360</display_length>
    <control>touch</control>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>
  <supports>
    <control>touch</control>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>

  <translation type="gettext">speedometer</translation>
  <launchable type="desktop-id">io.github.nico359.speedometer.desktop</launchable>
  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.2.0" date="2026-05-18">
      <description translate="no">
        <p>Landscape and some other things.</p>
        <ul>
          <li>If switching to landscape mode or opening the app on desktop it behaves accordingly now</li>
          <li>Added Coordinates and Time to Fix (Time until dot turns green)</li>
          <li>Inhibit - screen does not go to sleep as long as the app is active</li>
          <li>Added smoothing of the analogue speed dial</li>
          <li>Added option to switch between km/h and mph</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-05-02">
      <description translate="no">
        <p>Initial release.</p>
        <ul>
          <li>Analogue dial with colour-coded speed arc (green → yellow → red)</li>
          <li>Large digital speed readout below the dial</li>
          <li>Altitude display</li>
          <li>GPS accuracy indicator with colour coding and status hints</li>
          <li>Location via the XDG Location Portal (geoclue)</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
